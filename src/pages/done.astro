---
import AppShell from '@/layouts/AppShell.astro';
import TaskList from '@/components/TaskList.tsx';
const user = Astro.locals.user;
---
<AppShell title="Hechas" active="done" userName={user?.name}>
  <h2 class="text-2xl font-bold mt-4">Completadas</h2>
  <TaskList view="done" client:load />
</AppShell>
