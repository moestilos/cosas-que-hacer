---
import AppShell from '@/layouts/AppShell.astro';
import TaskList from '@/components/TaskList.tsx';
import PageHeader from '@/components/PageHeader.tsx';
const user = Astro.locals.user;
const d = new Date();
const subtitle = d.toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });
---
<AppShell title="Hoy" active="today" userName={user?.name}>
  <PageHeader title="Hoy" subtitle={subtitle.charAt(0).toUpperCase() + subtitle.slice(1)} />
  <TaskList view="today" client:load />
</AppShell>
