---
import AppShell from '@/layouts/AppShell.astro';
import TaskList from '@/components/TaskList.tsx';
---
<AppShell title="Demo" active="today" demo={true}>
  <div class="pt-4">
    <div class="rounded-lg border border-warning/30 bg-warning/10 text-warning px-3 py-2 text-xs mb-4">
      Modo demo. Datos solo en este dispositivo. <a href="/signup" class="underline font-medium">Crea cuenta</a> para no perderlos.
    </div>
    <h2 class="text-2xl font-bold">Hoy</h2>
    <TaskList view="today" demo={true} client:load />
  </div>
</AppShell>
