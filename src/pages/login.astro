---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AuthForm from '@/components/AuthForm.tsx';
---
<BaseLayout title="Entrar">
  <div class="min-h-dvh flex flex-col items-center justify-center px-6 gap-6">
    <h1 class="text-2xl font-semibold">Entrar</h1>
    <AuthForm mode="login" client:load />
    <p class="text-sm text-muted">
      ¿Sin cuenta? <a href="/signup" class="text-primary hover:underline">Crear</a>
    </p>
    <a href="/demo" class="text-xs text-muted hover:text-text">O prueba sin registro</a>
  </div>
</BaseLayout>
