---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AuthForm from '@/components/AuthForm.tsx';
---
<BaseLayout title="Crear cuenta">
  <div class="min-h-dvh flex flex-col items-center justify-center px-6 gap-6">
    <h1 class="text-2xl font-semibold">Crear cuenta</h1>
    <AuthForm mode="signup" client:load />
    <p class="text-sm text-muted">
      ¿Ya tienes? <a href="/login" class="text-primary hover:underline">Entrar</a>
    </p>
  </div>
</BaseLayout>
