# ============================================
# NEON (Base de datos Postgres serverless)
# ============================================
# Crea un proyecto en: neon.tech → Dashboard → New Project
# Copia la "Connection string" (formato postgres://...)
DATABASE_URL=postgres://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ============================================
# CLERK (Autenticación)
# ============================================
# Crea una app en: clerk.com → Create application
# Copia las claves desde: Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# URLs de redirección de Clerk (dejar estos valores por defecto)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ============================================
# STRIPE (Pagos)
# ============================================
# Encuentra estos valores en: dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Se genera al configurar el webhook en Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
